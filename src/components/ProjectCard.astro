---
export interface Props {
  title: string;
  description: string;
  href?: string;
  tags?: string[];
  status?: 'active' | 'archived' | 'wip';
}

const { title, description, href, tags = [], status = 'active' } = Astro.props;

const statusLabels = {
  active: 'Active',
  archived: 'Archived',
  wip: 'In Progress',
};
---

<article class:list={['project-card', `project-card--${status}`]}>
  <div class="project-card__header">
    <h3 class="project-card__title">
      {href ? (
        <a href={href} class="project-card__link">{title}</a>
      ) : (
        title
      )}
    </h3>
    <span class:list={['project-card__status', `project-card__status--${status}`]}>
      {statusLabels[status]}
    </span>
  </div>
  <p class="project-card__desc">{description}</p>
  {tags.length > 0 && (
    <ul class="project-card__tags">
      {tags.map((tag) => (
        <li class="project-card__tag">{tag}</li>
      ))}
    </ul>
  )}
</article>

<style>
  .project-card {
    padding: var(--space-xl);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .project-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .project-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .project-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-tight);
  }

  .project-card__link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .project-card__link:hover {
    color: var(--color-accent);
  }

  .project-card__status {
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.15em 0.6em;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .project-card__status--active {
    background: #e8f5e9;
    color: #2e7d32;
  }

  .project-card__status--archived {
    background: var(--color-bg-subtle);
    color: var(--color-text-tertiary);
  }

  .project-card__status--wip {
    background: #fff3e0;
    color: #e65100;
  }

  .project-card__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    margin-bottom: var(--space-md);
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .project-card__tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    padding: 0.2em 0.6em;
    background: var(--color-bg-subtle);
    border-radius: var(--radius-sm);
  }
</style>
