---
export interface Props {
  title: string;
  description: string;
  filename: string;
  href?: string;
  tags?: string[];
  status?: 'active' | 'archived' | 'wip';
}

const { title, description, filename, href, tags = [], status = 'active' } = Astro.props;

const statusLabels = {
  active: '● active',
  archived: '● archived',
  wip: '● wip',
};
---

<article class:list={['project-card', `project-card--${status}`]}>
  <div class="project-card__top">
    <span class="project-card__filename">{filename}</span>
    <span class:list={['project-card__status', `project-card__status--${status}`]}>
      {statusLabels[status]}
    </span>
  </div>
  <h3 class="project-card__title">
    {href ? (
      <a href={href} class="project-card__link">{title}</a>
    ) : (
      title
    )}
  </h3>
  <p class="project-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="project-card__tags">
      {tags.map((tag) => (
        <span class="project-card__tag">{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  .project-card {
    padding: var(--space-xl);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    height: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity var(--transition-base);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .project-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .project-card__filename {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .project-card__status--active {
    --pill-bg: var(--color-accent-subtle);
    --pill-color: var(--color-accent);
  }

  .project-card__status--wip {
    --pill-bg: #FEFCE8;
    --pill-color: #CA8A04;
  }

  .project-card__status--archived {
    --pill-bg: var(--color-bg-subtle);
    --pill-color: var(--color-text-tertiary);
  }

  .project-card__status {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2em 0.7em;
    border-radius: var(--radius-full);
    background: var(--pill-bg, var(--color-accent-subtle));
    color: var(--pill-color, var(--color-accent));
    line-height: 1.5;
    white-space: nowrap;
    font-weight: var(--weight-medium);
  }

  .project-card__title {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-sm);
  }

  .project-card__link {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .project-card__link:hover {
    color: var(--color-accent);
  }

  .project-card__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-lg);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .project-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    background: var(--color-bg-subtle);
    padding: 0.3em 0.7em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }
</style>
