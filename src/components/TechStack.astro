---
const categories = [
  {
    label: 'Languages',
    items: [
      { name: 'Go', proficiency: 5 },
      { name: 'Python', proficiency: 5 },
      { name: 'TypeScript', proficiency: 3 },
      { name: 'C', proficiency: 3 },
      { name: 'C++', proficiency: 3 },
      { name: 'Java', proficiency: 3 },
      { name: 'Bash', proficiency: 4 },
    ],
  },
  {
    label: 'Cloud & Infrastructure',
    items: [
      { name: 'Kubernetes', proficiency: 5 },
      { name: 'OpenStack', proficiency: 5 },
      { name: 'OpenShift', proficiency: 3 },
      { name: 'AWS', proficiency: 3 },
      { name: 'Docker', proficiency: 5 },
      { name: 'Containerd', proficiency: 3 },
      { name: 'LXC', proficiency: 3 },
      { name: 'Terraform', proficiency: 4 },
      { name: 'Ceph', proficiency: 4 },
    ],
  },
  {
    label: 'DevOps & CI/CD',
    items: [
      { name: 'Ansible', proficiency: 5 },
      { name: 'Jenkins', proficiency: 4 },
      { name: 'ArgoCD', proficiency: 4 },
      { name: 'GitOps', proficiency: 4 },
      { name: 'Vagrant', proficiency: 3 },
    ],
  },
  {
    label: 'Backend & Web',
    items: [
      { name: 'FastAPI', proficiency: 4 },
      { name: 'Flask', proficiency: 4 },
      { name: 'Django', proficiency: 3 },
      { name: 'Gin', proficiency: 4 },
      { name: 'Fiber', proficiency: 3 },
      { name: 'Nginx', proficiency: 3 },
      { name: 'Apache', proficiency: 3 },
    ],
  },
  {
    label: 'Data & Monitoring',
    items: [
      { name: 'MySQL', proficiency: 3 },
      { name: 'MongoDB', proficiency: 3 },
      { name: 'PostgreSQL', proficiency: 3 },
      { name: 'OpenSearch', proficiency: 4 },
      { name: 'ELK Stack', proficiency: 3 },
      { name: 'Fluentd', proficiency: 4 },
    ],
  },
];
---

<section class="tech-stack" id="stack">
  <div class="container--wide section">
    <p class="section-label reveal">// stack</p>
    <div class="tech-stack__grid">
      {categories.map((category) => (
        <div class="tech-stack__category reveal">
          <h3 class="tech-stack__category-label">{category.label}</h3>
          <ul class="tech-stack__items">
            {category.items.map((item) => (
              <li class="tech-stack__item">
                <span class="stack-name">{item.name}</span>
                <span class="stack-dots" aria-label={`${item.proficiency} out of 5`}>
                  {Array.from({ length: 5 }, (_, i) => (
                    <span class:list={['stack-dot', { 'stack-dot--filled': i < item.proficiency }]}></span>
                  ))}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tech-stack__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-md);
  }

  .tech-stack__category {
    padding: var(--space-xl);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .tech-stack__category::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-accent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .tech-stack__category:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--color-accent);
  }

  .tech-stack__category:hover::before { opacity: 1; }

  .tech-stack__category-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .tech-stack__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .tech-stack__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .stack-name {
    flex-shrink: 0;
  }

  .stack-dots {
    display: flex;
    gap: 3px;
    flex-shrink: 0;
  }

  .stack-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--color-border);
  }

  .stack-dot--filled {
    background: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .tech-stack__grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .tech-stack__grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .tech-stack__grid { grid-template-columns: 1fr; }
  }
</style>
