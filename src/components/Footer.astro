---
const currentYear = new Date().getFullYear();
---

<footer class="footer" id="contact">
  <div class="footer__inner container--wide">
    <div class="footer__top">
      <p class="footer__cta">Let's work together</p>
      <a href="mailto:0albayrakharun@gmail.com" class="footer__email">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        0albayrakharun@gmail.com
      </a>
    </div>
    <div class="footer__bottom">
      <p class="footer__copy">&copy; {currentYear} Harun Albayrak</p>
      <nav class="footer__links" aria-label="Links">
        <a href="https://github.com/harunalbayrak" target="_blank" rel="noopener noreferrer" class="footer__link" aria-label="GitHub">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span>github</span>
        </a>
        <a href="https://linkedin.com/in/harunalbayrak" target="_blank" rel="noopener noreferrer" class="footer__link" aria-label="LinkedIn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          <span>linkedin</span>
        </a>
        <a href="/rss.xml" class="footer__link" aria-label="RSS">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
          <span>rss</span>
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .footer__top {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
  }

  .footer__cta {
    font-size: var(--text-md);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
  }

  .footer__email {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__email:hover {
    color: var(--color-accent-hover);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .footer__links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__link svg {
    opacity: 0.6;
    transition: opacity var(--transition-fast);
  }

  .footer__link:hover svg {
    opacity: 1;
  }

  @media (max-width: 480px) {
    .footer__top {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-md);
      align-items: flex-start;
    }
  }
</style>
