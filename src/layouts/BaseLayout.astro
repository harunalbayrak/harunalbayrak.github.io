---
import { ViewTransitions } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  publishDate?: Date;
}

const { title, description, ogImage, ogType, publishDate } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <ViewTransitions />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      publishDate={publishDate}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
