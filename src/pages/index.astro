---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Education from '../components/Education.astro';
import Experience from '../components/Experience.astro';
import ProjectCard from '../components/ProjectCard.astro';
import WritingPreview from '../components/WritingPreview.astro';
import TechStack from '../components/TechStack.astro';
import Certificates from '../components/Certificates.astro';

const educationItems = [
  {
    school: 'Kocaeli University',
    degree: 'M.Sc. in Software Engineering',
    period: 'Sep 2024 – Present',
    description: 'Advanced coursework in software architecture, distributed systems, and security engineering.',
  },
  {
    school: 'Gebze Technical University',
    degree: 'B.Sc. in Computer Engineering',
    period: 'Sep 2017 – Jun 2022',
    description: 'Graduated with a strong foundation in computer science. Key areas: data structures & algorithms, object-oriented programming, system programming (concurrency, threads, processes), and operating systems.',
  },
];

const experienceItems = [
  {
    company: 'TÜBİTAK',
    role: 'Software & DevOps Engineer',
    period: 'Apr 2022 – Present',
    duration: '4 years 2 months',
    description: 'Working on Safir Cloud, a large-scale OpenStack-based cloud infrastructure. Automating deployments, building Kubernetes services, and designing GitOps pipelines for multi-cloud management.',
    tags: ['Kubernetes', 'OpenStack', 'Go', 'Ansible', 'Terraform', 'ArgoCD'],
  },
  {
    company: 'Berqnet',
    role: 'DevOps Engineer (Part-Time)',
    period: 'Jun 2021 – Feb 2022',
    duration: '9 months',
    description: 'Automated build and test pipelines for a FreeBSD-based firewall system. Built CI/CD workflows with Jenkins and containerized test environments with Docker.',
    tags: ['Jenkins', 'Docker', 'Ansible', 'FreeBSD', 'Shell'],
  },
];

const projects = [
  {
    filename: 'borsasentez.ts',
    title: 'BorsaSentez',
    description: 'A stock market analysis tool that helps investors make data-driven decisions. Built with a focus on clean UX and real-time data processing.',
    href: '#',
    tags: ['TypeScript', 'React'],
    status: 'wip' as const,
  },
];

const recentPosts = [
  {
    filename: 'on-the-quiet-craft.md',
    title: 'On the Quiet Craft of Software',
    description: "Why the best engineering often goes unnoticed — and why that's the point.",
    href: '/blog/on-the-quiet-craft',
    date: new Date('2026-05-15'),
  },
  {
    filename: 'tools-should-get-out.md',
    title: 'Tools Should Get Out of the Way',
    description: 'A reflection on developer experience and the tools we choose to keep.',
    href: '/blog/tools-should-get-out',
    date: new Date('2026-04-28'),
  },
  {
    filename: 'thinking-in-systems.md',
    title: 'Thinking in Systems',
    description: 'How understanding feedback loops changed the way I design software.',
    href: '/blog/thinking-in-systems',
    date: new Date('2026-03-10'),
  },
];

const certs = [
  {
    logo: '/lf-logo.png',
    logoAlt: 'The Linux Foundation',
    issuer: 'The Linux Foundation',
    title: 'Certified Kubernetes Administrator',
    badge: 'CKA',
  },
];
---

<BaseLayout
  title="Harun Albayrak"
  description="Software & DevOps Engineer — cloud-native development, Kubernetes, OpenStack, and infrastructure automation."
>
  <Hero />

  <hr class="section-divider" />
  <About />

  <hr class="section-divider" />
  <Experience items={experienceItems} />

  <hr class="section-divider" />
  <Education items={educationItems} />

  <hr class="section-divider" />
  <section id="projects" class="section">
    <div class="container--wide">
      <p class="section-label reveal">// projects</p>
      <div class="projects-grid">
        {projects.map((project, i) => (
          <div class="reveal" data-reveal data-delay={i * 100}>
            <ProjectCard {...project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />
  <WritingPreview posts={recentPosts} />

  <hr class="section-divider" />
  <TechStack />

  <hr class="section-divider" />
  <Certificates items={certs} />
</BaseLayout>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = entry.target.getAttribute('data-delay') || '0';
            entry.target.style.transitionDelay = `${delay}ms`;
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal').forEach((el, i) => {
      if (!el.hasAttribute('data-delay')) {
        el.setAttribute('data-delay', String(i * 60));
      }
      observer.observe(el);
    });
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('visible'));
  }
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .projects-grid {
    display: grid;
    gap: var(--space-md);
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

</style>
